# =============================================================================
# AI LOG ANALYZER — KONFIGURACE PROSTŘEDÍ
# =============================================================================
#
# POSTUP:
#   1. Zkopíruj tento soubor:  cp .env.example .env
#   2. Vyplň hodnoty pro své prostředí (nprod / prod)
#   3. Spusť instalační skript:  ./install.sh
#
# Install skript na základě tohoto souboru:
#   - Vytvoří DB schéma a oprávnění
#   - Buildne a pushne Docker image
#   - Vygeneruje values.yaml pro K8s infra-apps repozitář
#   - Commitne a pushne novou branch (pro PR)
#
# =============================================================================

# =============================================================================
# 1. PROSTŘEDÍ
# =============================================================================
ENVIRONMENT=nprod                        # nprod | prod

# =============================================================================
# 2. DOCKER IMAGE
# =============================================================================
DOCKER_REGISTRY=dockerhub.kb.cz
DOCKER_SQUAD=<your_squad>               # např: pccm-sq016
IMAGE_TAG=<tag>                          # např: r63

# =============================================================================
# 3. GIT REPOZITÁŘE
# =============================================================================
# Cesta k ai-log-analyzer zdrojovému kódu (tento repozitář)
ANALYZER_REPO_DIR=<path_to_this_repo>    # např: /home/user/git/ai-log-analyzer

# Cesta ke K8s infra-apps repozitáři (kam se deployjí manifesty)
#   nprod: <git_root>/k8s-infra-apps-nprod/infra-apps/ai-log-analyzer
#   prod:  <git_root>/k8s-infra-apps-prod/infra-apps/ai-log-analyzer
INFRA_APPS_DIR=<path_to_infra_apps>      # např: /home/user/git/k8s-infra-apps-nprod/infra-apps/ai-log-analyzer

# =============================================================================
# 4. POSTGRESQL DATABASE
# =============================================================================
#   nprod: P050TD01.DEV.KB.CZ
#   prod:  <prod_db_host>
DB_HOST=<db_hostname>
DB_PORT=5432
DB_NAME=ailog_analyzer

# App user — runtime (SELECT, INSERT, UPDATE, DELETE na ailog_peak.*)
DB_USER=<app_user>
DB_PASSWORD=<app_password>

# DDL user — migrace (CREATE TABLE, ALTER, GRANT, SET ROLE)
DB_DDL_USER=<ddl_user>
DB_DDL_PASSWORD=<ddl_password>
DB_DDL_ROLE=role_ailog_analyzer_ddl

# =============================================================================
# 5. ELASTICSEARCH
# =============================================================================
#   nprod: https://elasticsearch-test.kb.cz:9500
#   prod:  https://elasticsearch.kb.cz:9500
ES_HOST=<es_url>
ES_INDEX=cluster-app_<prefix>-*          # např: cluster-app_pcb-*,cluster-app_pca-*,cluster-app_pcb_ch-*
ES_USER=<es_read_user>                   # Technický účet — musí být založen a registrován v CyberArk
ES_PASSWORD=<es_password>
ES_VERIFY_CERTS=false

# =============================================================================
# 6. CONFLUENCE
# =============================================================================
CONFLUENCE_URL=https://wiki.kb.cz
CONFLUENCE_TOKEN=<confluence_api_token>  # API token (= heslo služebního účtu)
CONFLUENCE_USERNAME=<confluence_user>    # Služební účet (založit nebo sdílený, např. XX_AWX_CONFLUENCE)

# Page IDs — vytvořit stránky a zkopírovat ID z URL
CONFLUENCE_KNOWN_ERRORS_PAGE_ID=<page_id>
CONFLUENCE_KNOWN_PEAKS_PAGE_ID=<page_id>
CONFLUENCE_RECENT_INCIDENTS_PAGE_ID=<page_id>

# Proxy pro přístup z K8s
CONFLUENCE_PROXY=http://cntlm.speed-default:3128

# =============================================================================
# 7. TEAMS NOTIFICATIONS
# =============================================================================
TEAMS_WEBHOOK_URL=<webhook_url>
TEAMS_EMAIL=<teams_channel_email>        # Email adresa Teams kanálu
TEAMS_ENABLED=true

# =============================================================================
# 8. EMAIL (SMTP)
# =============================================================================
SMTP_HOST=css-smtp-prod-os.sos.kb.cz
SMTP_PORT=25
EMAIL_FROM=ai-log-analyzer@kb.cz

# =============================================================================
# 9. CYBERARK / CONJUR
# =============================================================================
CONJUR_APP_ID=<PSIAM_APP_ID>            # Application Identity z PSIAM (např. AI-LOG-ANALYZER)
CONJUR_LOB_USER=CAR_TA_LOBUser_<ENV>    # nprod: CAR_TA_LOBUser_TEST | prod: CAR_TA_LOBUser_PROD
CONJUR_SAFE_NAME=DAN_<SAFE_NAME>        # Název SPEED safe (např. DAN_AI-LOG-ANALYZER)

# Názvy účtů v CyberArk safe (account name, ne username)
CONJUR_ACCOUNT_DB=<db_dml_account>       # např: ailog_analyzer_user_d1
CONJUR_ACCOUNT_DB_DDL=<db_ddl_account>   # např: ailog_analyzer_ddl_user_d1
CONJUR_ACCOUNT_ES=<es_account>           # např: XX_PCBS_ES_READ
CONJUR_ACCOUNT_CONFLUENCE=<confluence_account>  # např: XX_AWX_CONFLUENCE

# =============================================================================
# 10. NAMESPACE MONITORING
# =============================================================================
# Čárkou oddělené Kubernetes namespace pro monitoring.
# Tyto namespace budou hledány v ES_INDEX pattern.
MONITORED_NAMESPACES=<ns1>,<ns2>,<ns3>
# Příklad:
# MONITORED_NAMESPACES=pcb-dev-01-app,pcb-sit-01-app,pcb-uat-01-app,pca-dev-01-app,pca-sit-01-app,pca-uat-01-app

# =============================================================================
# 11. PEAK DETECTION & ALERTING (defaulty — většinou není třeba měnit)
# =============================================================================
PERCENTILE_LEVEL=0.93
MIN_SAMPLES_FOR_THRESHOLD=10
DEFAULT_THRESHOLD=100
SPIKE_THRESHOLD=3.0
EWMA_ALPHA=0.3
WINDOW_MINUTES=15
MAX_PEAK_ALERTS_PER_WINDOW=3
ALERT_DIGEST_ENABLED=true
ALERT_COOLDOWN_MIN=45
ALERT_HEARTBEAT_MIN=120
ALERT_MIN_DELTA_PCT=30
ALERT_CONTINUATION_LOOKBACK_MIN=60

# =============================================================================
# 12. INIT JOB — bootstrap parametry
# =============================================================================
INIT_BACKFILL_DAYS=21
INIT_BACKFILL_WORKERS=4
INIT_THRESHOLD_WEEKS=3

# =============================================================================
# 13. OLLAMA LLM (TBD — připraveno pro budoucí verzi s AI analýzou)
# =============================================================================
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral:latest

# =============================================================================
# 14. LOGGING & DEBUG
# =============================================================================
LOG_LEVEL=INFO
