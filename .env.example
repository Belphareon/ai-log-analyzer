# =============================================================================
# AI LOG ANALYZER - ENVIRONMENT VARIABLES
# =============================================================================
# Kopíruj do .env a vyplň hodnoty pro své prostředí.
# .env soubor je v .gitignore a NEBUDE commitován.
#
# V K8s se tyto proměnné NEPOUŽÍVAJÍ — místo toho se nastavují
# přes values.yaml + Conjur Secret (viz docs/INSTALLATION.md).
# =============================================================================

# -----------------------------------------------------------------------------
# ELASTICSEARCH
# -----------------------------------------------------------------------------
ES_HOST=https://elasticsearch-test.kb.cz:9500
ES_INDEX=cluster-app_<prefix>-*
ES_USER=<es_read_user>
ES_PASSWORD=<es_password>
ES_VERIFY_CERTS=false

# -----------------------------------------------------------------------------
# POSTGRESQL DATABASE
# -----------------------------------------------------------------------------
# App user (SELECT, INSERT, UPDATE, DELETE)
DB_HOST=<db_hostname>
DB_PORT=5432
DB_NAME=ailog_analyzer
DB_USER=<app_user>
DB_PASSWORD=<app_password>

# DDL user (CREATE TABLE, ALTER, GRANT — pro migrace)
DB_DDL_USER=<ddl_user>
DB_DDL_PASSWORD=<ddl_password>
DB_DDL_ROLE=role_ailog_analyzer_ddl

# -----------------------------------------------------------------------------
# CONFLUENCE
# -----------------------------------------------------------------------------
CONFLUENCE_URL=https://wiki.kb.cz
CONFLUENCE_USERNAME=<confluence_user>
CONFLUENCE_PASSWORD=<confluence_token>
CONFLUENCE_API_TOKEN=<confluence_token>

# Page IDs (z URL Confluence stránek)
CONFLUENCE_KNOWN_ERRORS_PAGE_ID=<page_id>
CONFLUENCE_KNOWN_PEAKS_PAGE_ID=<page_id>
CONFLUENCE_RECENT_INCIDENTS_PAGE_ID=<page_id>

# Proxy (pokud vyžadováno)
# CONFLUENCE_PROXY=http://proxy:3128
# HTTP_PROXY=http://proxy:3128
# HTTPS_PROXY=http://proxy:3128

# -----------------------------------------------------------------------------
# TEAMS NOTIFICATIONS
# -----------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=<webhook_url>
TEAMS_ENABLED=true

# -----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS
# -----------------------------------------------------------------------------
SMTP_HOST=css-smtp-prod-os.sos.kb.cz
SMTP_PORT=25
EMAIL_FROM=ai-log-analyzer@kb.cz
TEAMS_EMAIL=<teams_channel_email>

# -----------------------------------------------------------------------------
# PEAK DETECTION
# -----------------------------------------------------------------------------
PERCENTILE_LEVEL=0.93
MIN_SAMPLES_FOR_THRESHOLD=10
DEFAULT_THRESHOLD=100
SPIKE_THRESHOLD=3.0
EWMA_ALPHA=0.3
WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# ALERTING
# -----------------------------------------------------------------------------
MAX_PEAK_ALERTS_PER_WINDOW=3
ALERT_DIGEST_ENABLED=true
ALERT_COOLDOWN_MIN=45
ALERT_HEARTBEAT_MIN=120
ALERT_MIN_DELTA_PCT=30
ALERT_CONTINUATION_LOOKBACK_MIN=60

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
ENVIRONMENT=nprod
LOG_LEVEL=INFO
REGISTRY_DIR=registry
EXPORT_DIR=scripts/exports
